<?xml version="1.0" encoding="utf-8"?>
<!--
    Capture screen for PortraitCaptureActivity. It swaps zxing's default centred
    viewfinder for a big square with the Universal logo in its centre (an alignment
    guide, matching the icon on the host QR) and a caption underneath. The overlay is
    purely visual: the DecoratedBarcodeView still scans the whole camera frame (see
    PortraitCaptureActivity, which sets the decode margin to zero and hides zxing's
    own viewfinder + status text).
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/zxing_barcode_scanner"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Visual-only overlay, centred over the preview. Not clickable, so touches
         fall through to the camera view underneath. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="false"
        android:focusable="false">

        <FrameLayout
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:background="@drawable/scan_frame">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:alpha="0.85"
                android:contentDescription="@null"
                android:src="@drawable/app_icon" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="#99000000"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="@string/scan_prompt"
            android:textColor="@android:color/white"
            android:textSize="16sp" />
    </LinearLayout>
</FrameLayout>
